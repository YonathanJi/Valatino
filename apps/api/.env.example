# ============================================================
# Variables de entorno — apps/api (NestJS)
# Copiar a .env para desarrollo local
# NUNCA exponer estas variables al cliente
# ============================================================

# Servidor
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# Stripe (clave SECRETA — solo servidor)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (credenciales secretas — solo servidor)
PAYPAL_CLIENT_ID=<paypal-client-id>
PAYPAL_CLIENT_SECRET=<paypal-client-secret>
PAYPAL_WEBHOOK_ID=<paypal-webhook-id>
PAYPAL_ENVIRONMENT=sandbox

# CORS
CORS_ORIGIN=http://localhost:3000

# SMTP (email transaccional — mismo SMTP configurable en Supabase Auth para OTP)
# SendGrid: host smtp.sendgrid.net, user literal "apikey", pass = API key (SG....)
# EMAIL_FROM debe coincidir con el remitente verificado en el proveedor
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=465
SMTP_USER=apikey
SMTP_PASS=SG....
EMAIL_FROM=Valatino <noreply@valatino.es>
